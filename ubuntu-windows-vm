system_install() {
  local INSTALL_DIR="/opt/ubuntu-vm-scripts"
  local BIN_DIR="/usr/local/bin"

  if [[ "$EUID" -ne 0 ]]; then
    exec sudo bash "$0" system-install
    exit $?
  fi

  echo "Installing scripts to $INSTALL_DIR ..."
  mkdir -p "$INSTALL_DIR"

  # Copy all scripts from the same directory as this script
  local src_dir
  src_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  for f in "$src_dir"/ubuntu-*; do
    [[ -f "$f" ]] || continue
    install -m 755 "$f" "$INSTALL_DIR/"
    msg_success "Installed: $(basename "$f")"
  done
  if [[ -f "$src_dir/looking-glass-install" ]]; then
    install -m 755 "$src_dir/looking-glass-install" "$INSTALL_DIR/"
  fi

  # Create symlinks in /usr/local/bin
  local -A symlinks=(
    ["windows-vm"]="ubuntu-windows-vm"
    ["gpu-passthrough"]="ubuntu-gpu-passthrough"
    ["snapshot"]="ubuntu-snapshot"
    ["looking-glass-install"]="ubuntu-looking-glass-install"
    ["qemu-patch"]="ubuntu-qemu-patch"
  )
  for link in "${!symlinks[@]}"; do
    local target="$INSTALL_DIR/${symlinks[$link]}"
    [[ -f "$target" ]] || continue
    ln -sf "$target" "$BIN_DIR/$link"
    msg_success "Symlink: $BIN_DIR/$link → $target"
  done

  echo ""
  msg_success "Scripts installed. Available commands:"
  echo ""
  echo "  gpu-passthrough       windows-vm       looking-glass-install"
  echo "  qemu-patch            snapshot"
  echo ""
  echo "Next steps:"
  echo ""
  echo "  1. gpu-passthrough setup       # Configure IOMMU and VFIO (reboot required)"
  echo "  2. looking-glass-install       # Install Looking Glass shared memory display"
  echo "  3. windows-vm install          # Install Windows VM"
  echo "  4. qemu-patch                  # (optional) Deep anti-detection: patch QEMU"
  echo "                                 #   strings at compile time (20-40 min build)"
  echo ""
  echo "  After Windows installs, check msinfo32 → System Summary → BIOS Version/Date"
  echo "  It should show your real motherboard BIOS, not SeaBIOS or OVMF defaults."
  echo ""
}

# Main command dispatcher
case "$1" in
install)
  install_windows
  ;;
system-install)
  system_install
  ;;
remove)
  remove_windows
  ;;
launch | start)
  shift # Remove the command name from arguments
  launch_windows "$@"
  ;;
stop | down)
  stop_windows
  ;;
status)
  status_windows
  ;;
show-compose)
  show_compose
  ;;
help | --help | -h | "")
  show_usage
  ;;
*)
  echo "Unknown command: $1" >&2
  echo "" >&2
  show_usage >&2
  exit 1
  ;;
esac
