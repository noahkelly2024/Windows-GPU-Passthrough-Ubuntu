#!/bin/bash
# ubuntu-looking-glass-install - Install Looking Glass client for VM display

# Preserve original script arguments for exec sg kvm (group refresh)
ORIGINAL_SCRIPT_ARGS=("$@")

SPICE_DIR="/var/run/ubuntu-windows"
SPICE_SOCKET_PATH="$SPICE_DIR/spice.sock"

# Source shared utilities if available
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/ubuntu-gpu-passthrough-utils" ]]; then
  # shellcheck source=ubuntu-gpu-passthrough-utils
  source "$SCRIPT_DIR/ubuntu-gpu-passthrough-utils"
else
  msg_error()   { echo "❌  Error: $*" >&2; }
  msg_warning() { echo "⚠️  Warning: $*" >&2; }
  msg_success() { echo "✓  $*"; }
  msg_info()    { echo "ℹ️  $*"; }
fi

format_escape_key_name() {
  case "$1" in
    KEY_SCROLLLOCK) echo "Scroll Lock" ;;
    KEY_RIGHTCTRL)  echo "Right Ctrl" ;;
    KEY_LEFTCTRL)   echo "Left Ctrl" ;;
    KEY_RIGHTALT)   echo "Right Alt" ;;
    KEY_PAUSE)      echo "Pause" ;;
    KEY_INSERT)     echo "Insert" ;;
    *) echo "${1#KEY_}" ;;
  esac
}

create_tmpfiles_config() {
  local tmpfiles_config_file="/etc/tmpfiles.d/ubuntu-windows.conf"

  msg_info "Configuring SPICE directory auto-creation..."

  sudo tee "$tmpfiles_config_file" >/dev/null <<'EOF'
# Ubuntu Windows VM - SPICE socket directory
# Auto-created on boot by systemd-tmpfiles
d /var/run/ubuntu-windows 0770 root kvm - -
EOF

  if sudo systemd-tmpfiles --create "$tmpfiles_config_file" 2>/dev/null; then
    msg_success "SPICE directory tmpfiles configured"
    if [[ -d "$SPICE_DIR" ]]; then
      local perms owner
      perms=$(stat -c "%a" "$SPICE_DIR" 2>/dev/null)
      owner=$(stat -c "%U:%G" "$SPICE_DIR" 2>/dev/null)
      if [[ "$perms" == "770" ]] && [[ "$owner" == "root:kvm" ]]; then
        msg_success "SPICE directory ready: $SPICE_DIR"
      else
        msg_warning "SPICE directory created but permissions may be incorrect (got: $perms $owner)"
      fi
    else
      msg_warning "SPICE directory not created (will be created on next boot)"
    fi
  else
    msg_warning "Failed to apply tmpfiles configuration (will be created on next boot)"
  fi
}

create_sudoers_config() {
  local sudoers_file="/etc/sudoers.d/ubuntu-looking-glass"

  local sudoers_content="# Ubuntu Looking Glass - Passwordless Operations
# Generated by ubuntu-looking-glass-install

# SPICE socket detection and permissions
$USER ALL=(ALL) NOPASSWD: /usr/bin/test -S /var/run/ubuntu-windows/spice.sock
$USER ALL=(ALL) NOPASSWD: /usr/bin/chmod 660 /var/run/ubuntu-windows/spice.sock
$USER ALL=(ALL) NOPASSWD: /usr/bin/chgrp kvm /var/run/ubuntu-windows/spice.sock

# SPICE directory creation (fallback if tmpfiles.d fails)
$USER ALL=(ALL) NOPASSWD: /usr/bin/mkdir -p /var/run/ubuntu-windows

# KVMFR module (Looking Glass shared memory)
$USER ALL=(ALL) NOPASSWD: /usr/bin/modprobe kvmfr, /usr/bin/modprobe kvmfr static_size_mb=*
$USER ALL=(ALL) NOPASSWD: /sbin/modprobe kvmfr, /sbin/modprobe kvmfr static_size_mb=*
"

  local temp_file
  temp_file=$(mktemp)
  echo "$sudoers_content" > "$temp_file"

  if ! sudo visudo -c -f "$temp_file" 2>&1 | grep -q "parsed OK"; then
    msg_error "Sudoers syntax validation failed!"
    echo "Generated content (for debugging):"
    cat "$temp_file"
    rm -f "$temp_file"
    return 1
  fi
  msg_success "Sudoers syntax validated"

  if sudo install -m 440 -o root -g root "$temp_file" "$sudoers_file"; then
    rm -f "$temp_file"
    if sudo visudo -c 2>&1 | grep -q "parsed OK"; then
      msg_success "Sudoers rules installed: $sudoers_file"
    else
      msg_error "Overall sudoers check failed! Removing."
      sudo rm -f "$sudoers_file"
      return 1
    fi
  else
    msg_error "Failed to install sudoers rules"
    rm -f "$temp_file"
    return 1
  fi
}

# ── Prompt helpers (gum with readline fallback) ──────────────────────────────

gum_choose() {
  # Usage: gum_choose DEFAULT_INDEX "opt1" "opt2" ...
  # Prints the chosen option text
  local default_idx="$1"; shift
  if command -v gum &>/dev/null; then
    gum choose --selected="${!default_idx}" "$@"
    return
  fi
  local i=1
  for opt in "$@"; do
    if [[ "$((i-1))" -eq "$default_idx" ]]; then
      echo "  $i) $opt  (default)"
    else
      echo "  $i) $opt"
    fi
    i=$((i+1))
  done
  read -rp "Enter number [$((default_idx+1))]: " choice
  choice="${choice:-$((default_idx+1))}"
  local opts=("$@")
  echo "${opts[$((choice-1))]}"
}

# ── Package installation (Ubuntu/apt only) ───────────────────────────────────

install_apt_packages() {
  local -a pkgs=("$@")
  msg_info "Installing: ${pkgs[*]}"
  if ! sudo apt-get install -y "${pkgs[@]}" 2>&1; then
    return 1
  fi
}

# ── kvmfr DKMS installation (Ubuntu) ─────────────────────────────────────────

install_kvmfr_ubuntu() {
  # Check if module already exists
  if modinfo kvmfr &>/dev/null; then
    msg_success "kvmfr kernel module already built"
    return 0
  fi

  msg_info "Installing kvmfr DKMS module..."

  # Ensure build dependencies
  install_apt_packages dkms "linux-headers-$(uname -r)" build-essential || {
    msg_warning "Some build dependencies may be missing"
  }

  # Try apt first (some PPAs package kvmfr-dkms)
  if sudo apt-get install -y kvmfr-dkms 2>/dev/null; then
    msg_success "kvmfr-dkms installed from apt"
    return 0
  fi

  # Build from Looking Glass source
  # The kvmfr DKMS module ships with Looking Glass. Download and build it.
  local LG_VERSION="B7"
  local BUILD_DIR
  BUILD_DIR=$(mktemp -d /tmp/looking-glass-build.XXXXXX)
  trap 'rm -rf "$BUILD_DIR"' RETURN

  msg_info "Downloading Looking Glass $LG_VERSION source for kvmfr module..."
  if ! command -v curl &>/dev/null; then
    sudo apt-get install -y curl 2>/dev/null || true
  fi

  local TARBALL="$BUILD_DIR/looking-glass.tar.gz"
  if ! curl -fL "https://looking-glass.io/artifact/$LG_VERSION/source" -o "$TARBALL" 2>/dev/null; then
    msg_error "Failed to download Looking Glass source"
    echo "   Download from: https://looking-glass.io/downloads"
    echo "   Then build kvmfr with: sudo dkms add ./looking-glass-$LG_VERSION/module"
    return 1
  fi

  tar -xzf "$TARBALL" -C "$BUILD_DIR" 2>/dev/null || {
    msg_error "Failed to extract Looking Glass source"
    return 1
  }

  local MODULE_DIR
  MODULE_DIR=$(find "$BUILD_DIR" -name "dkms.conf" -path "*/module/*" -exec dirname {} \; 2>/dev/null | head -1)
  if [[ -z "$MODULE_DIR" ]]; then
    msg_error "kvmfr module directory not found in source"
    return 1
  fi

  local MODULE_VER
  MODULE_VER=$(grep -oP 'PACKAGE_VERSION="\K[^"]+' "$MODULE_DIR/dkms.conf" 2>/dev/null || echo "0.0.1")

  sudo cp -r "$MODULE_DIR" "/usr/src/kvmfr-$MODULE_VER"
  if sudo dkms install "kvmfr/$MODULE_VER" 2>&1 | tail -5; then
    msg_success "kvmfr DKMS module built and installed (v$MODULE_VER)"
  else
    sudo rm -rf "/usr/src/kvmfr-$MODULE_VER"
    msg_error "DKMS build failed"
    echo "   Check: dkms status"
    echo "   Check: dmesg | grep kvmfr"
    return 1
  fi
}

# ── looking-glass-client installation (Ubuntu) ───────────────────────────────

install_looking_glass_client_binary() {
  if command -v looking-glass-client &>/dev/null; then
    msg_success "looking-glass-client already installed"
    return 0
  fi

  msg_info "Installing looking-glass-client..."

  # Try snap
  if command -v snap &>/dev/null; then
    if sudo snap install looking-glass-client 2>/dev/null; then
      # snap installs to /snap/bin — ensure it's in PATH
      export PATH="/snap/bin:$PATH"
      if command -v looking-glass-client &>/dev/null; then
        msg_success "looking-glass-client installed via snap"
        return 0
      fi
    fi
  fi

  # Try apt (available in some Ubuntu releases/PPAs)
  if sudo apt-get install -y looking-glass-client 2>/dev/null; then
    msg_success "looking-glass-client installed via apt"
    return 0
  fi

  msg_error "Could not install looking-glass-client automatically"
  echo ""
  echo "   Install it manually, then re-run this script."
  echo "   Options:"
  echo "     snap install looking-glass-client"
  echo "     Or build from source: https://looking-glass.io/docs/B7/install/"
  echo ""
  return 1
}

# ─────────────────────────────────────────────────────────────────────────────

echo "Installing Looking Glass B7..."
echo "Ultra-low latency VM display as an alternative to RDP."
echo ""

if ! sudo -v 2>/dev/null; then
  msg_error "sudo access required for installation"
  exit 1
fi

# Check Secure Boot (may block unsigned DKMS modules)
if command -v mokutil &>/dev/null; then
  if mokutil --sb-state 2>/dev/null | grep -qi "enabled"; then
    msg_warning "Secure Boot is ENABLED"
    echo "   DKMS modules (like kvmfr) may fail to load."
    echo "   If installation fails, disable Secure Boot in BIOS settings."
    echo ""
  fi
fi

# Install kvmfr DKMS and looking-glass-client
install_kvmfr_ubuntu || exit 1
install_looking_glass_client_binary || exit 1

# Verify DKMS module
msg_info "Verifying DKMS module..."
if ! modinfo kvmfr &>/dev/null; then
  msg_error "kvmfr module file not found!"
  echo "   DKMS build may have failed for current kernel: $(uname -r)"
  echo "   Check: dkms status"
  echo "   Check: sudo apt install linux-headers-$(uname -r)"
  exit 1
fi

dkms_status=$(dkms status 2>/dev/null | grep -i kvmfr || echo "")
if [[ -n "$dkms_status" ]]; then
  msg_success "DKMS module: $dkms_status"
fi

# Configure udev rules
msg_info "Configuring udev rules..."
sudo tee /etc/udev/rules.d/99-kvmfr.rules >/dev/null <<'EOF'
SUBSYSTEM=="kvmfr", OWNER="root", GROUP="kvm", MODE="0660"
EOF
sudo udevadm control --reload-rules 2>/dev/null || true
sudo udevadm trigger 2>/dev/null || true
msg_success "Udev rules configured"

# ── IVSHMEM size selection ────────────────────────────────────────────────────

IVSHMEM_SIZE_FROM_ENV="${IVSHMEM_SIZE:-}"

if [[ "${FORCE_RECONFIGURE:-0}" != "1" ]] && [[ -f /etc/modprobe.d/kvmfr.conf ]]; then
  IVSHMEM_SIZE=$(grep -oP 'static_size_mb=\K\d+' /etc/modprobe.d/kvmfr.conf 2>/dev/null || echo "")
  if [[ -n "$IVSHMEM_SIZE" ]]; then
    msg_success "Kernel module already configured (${IVSHMEM_SIZE}MB)"
  else
    sudo rm -f /etc/modprobe.d/kvmfr.conf
    IVSHMEM_SIZE=""
  fi
fi

if [[ -n "$IVSHMEM_SIZE_FROM_ENV" ]]; then
  IVSHMEM_SIZE="$IVSHMEM_SIZE_FROM_ENV"
  msg_success "Using ${IVSHMEM_SIZE}MB shared memory (from VM config)"
  current_size=$(grep -oP 'static_size_mb=\K\d+' /etc/modprobe.d/kvmfr.conf 2>/dev/null || echo "0")
  if [[ "$current_size" != "$IVSHMEM_SIZE" ]]; then
    msg_info "Updating kernel module configuration (${current_size}MB → ${IVSHMEM_SIZE}MB)..."
    sudo tee /etc/modprobe.d/kvmfr.conf >/dev/null <<EOF
options kvmfr static_size_mb=$IVSHMEM_SIZE
EOF
  fi
fi

if [[ -z "${IVSHMEM_SIZE:-}" ]] || { [[ "${FORCE_RECONFIGURE:-0}" == "1" ]] && [[ -z "$IVSHMEM_SIZE_FROM_ENV" ]]; }; then
  available_ram_mb=$(free -m | awk '/^Mem:/{print $7}')
  if [[ "$available_ram_mb" -lt 512 ]]; then
    echo ""
    msg_warning "Low available RAM: ${available_ram_mb}MB — consider smaller IVSHMEM size"
  fi

  echo ""
  echo "Select Looking Glass shared memory size:"
  echo ""
  echo "  Resolution     Minimum   Recommended"
  echo "  1920×1080      32 MB     64 MB"
  echo "  2560×1440      64 MB     128 MB"
  echo "  3840×2160      128 MB    256 MB"
  echo ""
  echo "  Higher refresh rate (144Hz+) needs more memory."
  echo ""
  echo "  1) 1080p (32MB)  - minimal, low RAM"
  echo "  2) 1080p (64MB)  - recommended  (default)"
  echo "  3) 1440p (128MB)"
  echo "  4) 4K    (256MB)"
  echo ""
  read -rp "Enter number [2]: " RESOLUTION_CHOICE
  RESOLUTION_CHOICE="${RESOLUTION_CHOICE:-2}"

  case "$RESOLUTION_CHOICE" in
    1) IVSHMEM_SIZE=32;  RES_DISPLAY="1080p (minimal)" ;;
    3) IVSHMEM_SIZE=128; RES_DISPLAY="1440p" ;;
    4) IVSHMEM_SIZE=256; RES_DISPLAY="4K" ;;
    *) IVSHMEM_SIZE=64;  RES_DISPLAY="1080p" ;;
  esac

  msg_success "Allocated ${IVSHMEM_SIZE}MB shared memory (sufficient for ${RES_DISPLAY})"

  if ! [[ "$IVSHMEM_SIZE" =~ ^[0-9]+$ ]] || [[ "$IVSHMEM_SIZE" -lt 32 ]] || [[ "$IVSHMEM_SIZE" -gt 512 ]]; then
    msg_error "Invalid IVSHMEM_SIZE: $IVSHMEM_SIZE (must be 32-512)"
    exit 1
  fi

  msg_info "Writing kernel module configuration..."
  sudo tee /etc/modprobe.d/kvmfr.conf >/dev/null <<EOF
options kvmfr static_size_mb=$IVSHMEM_SIZE
EOF
fi

# Auto-load on boot
if [[ ! -f /etc/modules-load.d/kvmfr.conf ]]; then
  msg_info "Configuring kernel module auto-load..."
  echo "kvmfr" | sudo tee /etc/modules-load.d/kvmfr.conf >/dev/null
  msg_success "Kernel module auto-load configured"
fi

# ── kvm group membership ──────────────────────────────────────────────────────

if ! groups "$USER" | grep -q '\bkvm\b'; then
  sudo usermod -aG kvm "$USER"
  msg_success "Added $USER to kvm group"
  msg_info "Refreshing group membership for current session..."
  exec sg kvm "$0" "${ORIGINAL_SCRIPT_ARGS[@]}"
else
  msg_success "Already in kvm group"
fi

# ── Escape key / client config ────────────────────────────────────────────────

LG_CONFIG="$HOME/.config/looking-glass/client.ini"
ESCAPE_KEY_FROM_ENV="${ESCAPE_KEY:-}"
ESCAPE_KEY=""
ESCAPE_KEY_SOURCE=""

if [[ -n "$ESCAPE_KEY_FROM_ENV" ]]; then
  ESCAPE_KEY="$ESCAPE_KEY_FROM_ENV"
  ESCAPE_KEY_SOURCE="env"
elif [[ "${FORCE_RECONFIGURE:-0}" != "1" ]] && [[ -f "$LG_CONFIG" ]]; then
  ESCAPE_KEY=$(grep '^escapeKey=' "$LG_CONFIG" 2>/dev/null | cut -d= -f2 | head -1)
  [[ -n "$ESCAPE_KEY" ]] && ESCAPE_KEY_SOURCE="existing config"
fi

if [[ -z "$ESCAPE_KEY" ]]; then
  IS_LAPTOP=false
  for bat in /sys/class/power_supply/BAT*; do
    [[ -d "$bat" ]] && IS_LAPTOP=true && break
  done

  if [[ "$IS_LAPTOP" == true ]]; then
    DEFAULT_KEY="KEY_RIGHTCTRL"
  else
    DEFAULT_KEY="KEY_SCROLLLOCK"
  fi

  echo ""
  echo "Select Looking Glass capture toggle key:"
  echo "  Press this key to release mouse/keyboard from VM."
  echo ""
  echo "  1) Scroll Lock  (default for desktops)"
  echo "  2) Right Ctrl   (recommended for laptops)"
  echo "  3) Right Alt"
  echo "  4) Pause"
  echo "  5) Insert"
  echo ""
  if [[ "$DEFAULT_KEY" == "KEY_RIGHTCTRL" ]]; then
    read -rp "Enter number [2]: " ESCAPE_CHOICE
    ESCAPE_CHOICE="${ESCAPE_CHOICE:-2}"
  else
    read -rp "Enter number [1]: " ESCAPE_CHOICE
    ESCAPE_CHOICE="${ESCAPE_CHOICE:-1}"
  fi

  case "$ESCAPE_CHOICE" in
    2) ESCAPE_KEY="KEY_RIGHTCTRL" ;;
    3) ESCAPE_KEY="KEY_RIGHTALT" ;;
    4) ESCAPE_KEY="KEY_PAUSE" ;;
    5) ESCAPE_KEY="KEY_INSERT" ;;
    *) ESCAPE_KEY="KEY_SCROLLLOCK" ;;
  esac
fi

if [[ -n "$ESCAPE_KEY_SOURCE" ]]; then
  msg_success "Capture toggle key: $(format_escape_key_name "$ESCAPE_KEY") (from $ESCAPE_KEY_SOURCE)"
else
  msg_success "Capture toggle key: $(format_escape_key_name "$ESCAPE_KEY")"
fi

if [[ "$ESCAPE_KEY_SOURCE" == "existing config" ]]; then
  msg_success "Using existing configuration (preserved)"
else
  msg_info "Creating client configuration..."
  mkdir -p "$HOME/.config/looking-glass"
  cat >"$LG_CONFIG" <<EOF
[app]
shmFile=/dev/kvmfr0

[input]
rawMouse=yes
autoCapture=no
captureOnly=no
escapeKey=$ESCAPE_KEY
grabKeyboard=yes
captureOnFocus=no

[win]
fullScreen=no
borderless=no

[spice]
enable=yes
host=$SPICE_SOCKET_PATH
port=0
input=yes
audio=yes
clipboard=yes
clipboardToVM=yes
clipboardToLocal=yes

[audio]
periodSize=256
bufferLatency=5
micDefault=allow
micShowIndicator=no
EOF
  msg_success "Configuration created ($LG_CONFIG)"
fi

# ── System config (tmpfiles + sudoers) ───────────────────────────────────────

create_tmpfiles_config
create_sudoers_config

# ── Desktop launcher ──────────────────────────────────────────────────────────

msg_info "Installing desktop launcher..."
APPS_DIR="$HOME/.local/share/applications"
mkdir -p "$APPS_DIR"

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
WINDOWS_SCRIPT="$(dirname "$SCRIPT_PATH")/ubuntu-windows-vm"
ICON_PATH="$APPS_DIR/icons/windows.png"
if [[ ! -f "$ICON_PATH" ]]; then
  ICON_PATH="computer"
fi

cat >"$APPS_DIR/windows-looking-glass.desktop" <<DESKEOF
[Desktop Entry]
Name=Windows [Looking Glass]
Comment=Connect to Windows VM via Looking Glass (ultra-low latency)
Exec=$WINDOWS_SCRIPT launch --lg
Icon=$ICON_PATH
Terminal=false
Type=Application
Categories=System;Virtualization;
DESKEOF
msg_success "Desktop launcher installed"

# ── Load module ───────────────────────────────────────────────────────────────

msg_info "Loading kvmfr module..."
if lsmod | grep -q kvmfr; then
  if [[ ! -e /dev/kvmfr0 ]]; then
    echo "Module loaded but /dev/kvmfr0 missing — reloading..."
    sudo -n rmmod kvmfr 2>/dev/null || true
    if sudo -n modprobe kvmfr "static_size_mb=$IVSHMEM_SIZE" 2>/dev/null; then
      udevadm settle --timeout=5 2>/dev/null || sleep 1
      msg_success "Module reloaded"
    else
      msg_warning "Module reload failed (reboot required)"
    fi
  else
    module_size=$(cat /sys/module/kvmfr/parameters/static_size_mb 2>/dev/null || echo "0")
    if [[ "$module_size" != "$IVSHMEM_SIZE" ]]; then
      echo "Module loaded with wrong size (${module_size}MB → ${IVSHMEM_SIZE}MB) — reloading..."
      sudo -n rmmod kvmfr 2>/dev/null || true
      if sudo -n modprobe kvmfr "static_size_mb=$IVSHMEM_SIZE" 2>/dev/null; then
        udevadm settle --timeout=5 2>/dev/null || sleep 1
        msg_success "Module reloaded with ${IVSHMEM_SIZE}MB"
      else
        msg_warning "Module reload failed (reboot required)"
      fi
    else
      msg_success "Module already loaded (${IVSHMEM_SIZE}MB)"
    fi
  fi
else
  if sudo -n modprobe kvmfr "static_size_mb=$IVSHMEM_SIZE" 2>/dev/null; then
    udevadm settle --timeout=5 2>/dev/null || sleep 1
    msg_success "Module loaded"
  else
    msg_warning "Module load failed"
    if command -v mokutil &>/dev/null && mokutil --sb-state 2>/dev/null | grep -qi "enabled"; then
      echo "   Secure Boot is enabled — this may block unsigned DKMS modules!"
      echo "   Disable Secure Boot in BIOS or sign the module."
    else
      echo "   Try rebooting, then: sudo modprobe kvmfr"
      echo "   Or check: dmesg | grep -i kvmfr"
    fi
  fi
fi

if [[ -e /dev/kvmfr0 ]] && [[ ! -r /dev/kvmfr0 ]]; then
  msg_warning "/dev/kvmfr0 exists but not readable — re-login or reboot to refresh kvm group"
fi

# ── Summary ───────────────────────────────────────────────────────────────────

echo ""
echo "Installation complete!"
echo ""
echo "Capture toggle key: $(format_escape_key_name "$ESCAPE_KEY")"
echo "  To change: edit $LG_CONFIG  (set escapeKey=)"
echo ""

if ! lsmod | grep -q kvmfr || [[ ! -e /dev/kvmfr0 ]]; then
  msg_warning "Reboot required — kvmfr module not yet active"
  echo ""
  echo "After reboot, run Windows VM installation again:"
  echo "   ubuntu-windows-vm install"
  echo ""
else
  msg_success "Looking Glass ready!"
  echo ""
  echo "Next: install Windows VM with Looking Glass support"
  echo "   ubuntu-windows-vm install"
  echo ""
fi
